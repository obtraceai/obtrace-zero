FROM golang:1.24-alpine AS builder
WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /obtrace-zero ./cmd/cli

FROM alpine:3.21
RUN apk add --no-cache curl
COPY --from=builder /obtrace-zero /usr/local/bin/obtrace-zero
ENTRYPOINT ["obtrace-zero"]
